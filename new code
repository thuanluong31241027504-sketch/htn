        {0x7F,0x49,0x49,0x49,0x36}, // B
        {0x3E,0x41,0x41,0x41,0x22}, // C
        {0x7F,0x41,0x41,0x22,0x1C}, // D
        {0x7F,0x49,0x49,0x49,0x41}, // E
        {0x7F,0x09,0x09,0x09,0x01}, // F
        {0x3E,0x41,0x49,0x49,0x7A}, // G
        {0x7F,0x08,0x08,0x08,0x7F}, // H
        {0x00,0x41,0x7F,0x41,0x00}, // I
        {0x20,0x40,0x41,0x3F,0x01}, // J
        {0x7F,0x08,0x14,0x22,0x41}, // K
        {0x7F,0x40,0x40,0x40,0x40}, // L
        {0x7F,0x02,0x0C,0x02,0x7F}, // M
        {0x7F,0x04,0x08,0x10,0x7F}, // N
        {0x3E,0x41,0x41,0x41,0x3E}, // O
        {0x7F,0x09,0x09,0x09,0x06}, // P
        {0x3E,0x41,0x51,0x21,0x5E}, // Q
        {0x7F,0x09,0x19,0x29,0x46}, // R
        {0x46,0x49,0x49,0x49,0x31}, // S
        {0x01,0x01,0x7F,0x01,0x01}, // T
        {0x3F,0x40,0x40,0x40,0x3F}, // U
        {0x1F,0x20,0x40,0x20,0x1F}, // V
        {0x3F,0x40,0x38,0x40,0x3F}, // W
        {0x63,0x14,0x08,0x14,0x63}, // X
        {0x07,0x08,0x70,0x08,0x07}, // Y
        {0x61,0x51,0x49,0x45,0x43}, // Z
    };
    
    uint8_t idx = 0;
    if (c >= '0' && c <= '9') idx = c - '0' + 1;
    else if (c >= 'A' && c <= 'Z') idx = c - 'A' + 11;
    else if (c == ' ') idx = 0;
    else idx = 0;
    
    for (uint8_t i = 0; i < 5; i++) {
        OLED_WriteData(font[idx][i]);
    }
    OLED_WriteData(0x00);
}

void OLED_PrintString(char *str) {
    while (*str) {
        OLED_PrintChar(*str++);
    }
}

void OLED_PrintNumber(uint16_t num) {
    char buffer[16];
    sprintf(buffer, "%d", num);
    OLED_PrintString(buffer);
}

void OLED_DisplayDistance(uint16_t distance) {
    char dist_str[16];
    char status_str[16];
    
    sprintf(dist_str, "%4d mm", distance);
    
    if (distance < 100) {
        sprintf(status_str, "VERY CLOSE");
    } else if (distance < 500) {
        sprintf(status_str, "CLOSE");
    } else if (distance < 2000) {
        sprintf(status_str, "FAR");
    } else {
        sprintf(status_str, "NO TARGET");
    }
    
    OLED_SetCursor(0, 0);
    OLED_PrintString("BALLBOT");
    
    OLED_SetCursor(0, 2);
    OLED_PrintString("DIST:");
    
    OLED_SetCursor(48, 2);
    OLED_PrintString(dist_str);
    
    OLED_SetCursor(0, 4);
    OLED_PrintString("STATUS:");
    
    OLED_SetCursor(56, 4);
    OLED_PrintString(status_str);
    
    OLED_SetCursor(0, 6);
    OLED_PrintString("SENSOR:VL53L0X");
}

/* ========== VL53L0X FUNCTIONS ========== */
uint8_t VL53L0X_Init(void) {
    uint8_t model_id;
    uint8_t retry;
    
    UART_Print("[VL53L0X] Initializing on I2C2 (PB10,PB11)...\r\n");
    
    HAL_Delay(100);
    
    for (retry = 0; retry < 5; retry++) {
        if (HAL_I2C_Mem_Read(&hi2c2, VL53L0X_ADDR << 1, VL53L0X_REG_ID_MODEL, 
                              I2C_MEMADD_SIZE_8BIT, &model_id, 1, 100) == HAL_OK) {
            if (model_id == VL53L0X_EXPECTED_ID) break;
        }
        HAL_Delay(50);
    }
    
    if (model_id != VL53L0X_EXPECTED_ID) {
        UART_PrintNumber("[VL53L0X] ERROR: Model ID=0x", model_id, "\r\n");
        return 0;
    }
    
    UART_Print("[VL53L0X] OK! Model ID: 0xEE\r\n");
    
    uint8_t data = 0x02;
    HAL_I2C_Mem_Write(&hi2c2, VL53L0X_ADDR << 1, VL53L0X_REG_START, 
                      I2C_MEMADD_SIZE_8BIT, &data, 1, 100);
    
    UART_Print("[VL53L0X] Continuous measurement started!\r\n");
    return 1;
}

uint16_t VL53L0X_ReadDistance(void) {
    uint8_t buf[2];
    if (HAL_I2C_Mem_Read(&hi2c2, VL53L0X_ADDR << 1, VL53L0X_REG_DISTANCE, 
                          I2C_MEMADD_SIZE_8BIT, buf, 2, 100) != HAL_OK) {
        return 9999;
    }
    uint16_t raw = (buf[0] << 8) | buf[1];
    if (raw < 8190) {
        return raw;
    }
    return 9999;
}

/* UART Interrupt Callback */
void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
    if (huart->Instance == USART1) {
        if (uart_index < UART_BUFFER_SIZE - 1) {
            uart_buffer[uart_index++] = rx_data;
        }
        HAL_UART_Receive_IT(&huart1, &rx_data, 1);
    }
}

