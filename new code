int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_I2C1_Init();
    MX_I2C2_Init();
    MX_USART1_UART_Init();

    /* USER CODE BEGIN 2 */
    
    UART_Print("\r\n");
    UART_Print("========================================\r\n");
    UART_Print("     BALLBOT SYSTEM STARTING\r\n");
    UART_Print("========================================\r\n");
    
    LED_Blink(2, 200);
    
    /* Initialize OLED */
    OLED_Init();
    OLED_Clear();
    UART_Print("[OK] OLED initialized on I2C1 (PB6,PB7)\r\n");
    
    /* Initialize VL53L0X */
    laser_ok = VL53L0X_Init();
    if (laser_ok) {
        UART_Print("[OK] VL53L0X initialized on I2C2 (PB10,PB11)\r\n");
        LED_Blink(2, 100);
    } else {
        UART_Print("[ERROR] VL53L0X not found!\r\n");
        LED_Blink(10, 200);
    }
    
    /* Start UART receive interrupt */
    HAL_UART_Receive_IT(&huart1, &rx_data, 1);
    
    UART_Print("========================================\r\n");
    UART_Print("System ready. Commands: GET_DIST, LED_ON, LED_OFF\r\n");
    UART_Print("========================================\r\n");
    
    /* Display initial screen */
    OLED_DisplayDistance(laser_distance);
    
    /* USER CODE END 2 */

    while (1)
    {
        /* USER CODE BEGIN 3 */
        
        if (laser_ok) {
            uint16_t new_distance = VL53L0X_ReadDistance();
            
            if (new_distance != laser_distance) {
                laser_distance = new_distance;
                OLED_DisplayDistance(laser_distance);
                
                char auto_msg[32];
                sprintf(auto_msg, "Distance: %d mm", laser_distance);
                UART_SendResponse(auto_msg);
            }
        }
        
        ProcessUARTCommand();
        
        /* LED feedback */
        if (laser_distance < 100) {
            LED_Blink(1, 50);
        } else if (laser_distance < 500) {
            LED_Blink(1, 200);
        } else {
            LED_Off();
        }
        
        HAL_Delay(100);
        
        /* USER CODE END 3 */
    }
}

