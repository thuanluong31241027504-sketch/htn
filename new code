/* ========== UART FUNCTIONS ========== */
void UART_Print(const char *msg) {
    HAL_UART_Transmit(&huart1, (uint8_t*)msg, strlen(msg), 100);
}

void UART_PrintNumber(const char *prefix, uint32_t num, const char *suffix) {
    char buffer[64];
    int len = sprintf(buffer, "%s%lu%s", prefix, num, suffix);
    HAL_UART_Transmit(&huart1, (uint8_t*)buffer, len, 100);
}

void UART_SendResponse(const char *response) {
    char buffer[64];
    sprintf(buffer, "%s\r\n", response);
    HAL_UART_Transmit(&huart1, (uint8_t*)buffer, strlen(buffer), 100);
}

void ProcessUARTCommand(void) {
    if (uart_index > 0 && uart_buffer[uart_index-1] == '\n') {
        uart_buffer[uart_index-1] = '\0';
        
        if (strcmp(uart_buffer, "GET_DIST") == 0) {
            laser_distance = VL53L0X_ReadDistance();
            char resp[32];
            sprintf(resp, "Distance: %d mm", laser_distance);
            UART_SendResponse(resp);
            OLED_DisplayDistance(laser_distance);
        }
        else if (strcmp(uart_buffer, "LED_ON") == 0) {
            LED_On();
            UART_SendResponse("LED: ON");
        }
        else if (strcmp(uart_buffer, "LED_OFF") == 0) {
            LED_Off();
            UART_SendResponse("LED: OFF");
        }
        else if (strlen(uart_buffer) > 0) {
            UART_SendResponse("Unknown command");
        }
        
        uart_index = 0;
        memset(uart_buffer, 0, sizeof(uart_buffer));
    }
}

/* ========== LED FUNCTIONS ========== */
void LED_On(void) {
    HAL_GPIO_WritePin(LED_PORT, LED_PIN, GPIO_PIN_SET);
}

void LED_Off(void) {
    HAL_GPIO_WritePin(LED_PORT, LED_PIN, GPIO_PIN_RESET);
}

void LED_Blink(uint32_t times, uint32_t delay_ms) {
    for (uint32_t i = 0; i < times; i++) {
        LED_On();
        HAL_Delay(delay_ms);
        LED_Off();
        HAL_Delay(delay_ms);
    }
}

/* ========== OLED FUNCTIONS ========== */
void OLED_WriteCommand(uint8_t cmd) {
    uint8_t buffer[2] = {0x00, cmd};
    HAL_I2C_Master_Transmit(&hi2c1, OLED_ADDR << 1, buffer, 2, 100);
}

void OLED_WriteData(uint8_t data) {
    uint8_t buffer[2] = {0x40, data};
    HAL_I2C_Master_Transmit(&hi2c1, OLED_ADDR << 1, buffer, 2, 100);
}

void OLED_Init(void) {
    HAL_Delay(100);
    
    OLED_WriteCommand(0xAE);  // Display OFF
    OLED_WriteCommand(0xD5);  // Set display clock divide ratio
    OLED_WriteCommand(0x80);
    OLED_WriteCommand(0xA8);  // Set multiplex ratio (64)
    OLED_WriteCommand(0x3F);
    OLED_WriteCommand(0xD3);  // Set display offset (0)
    OLED_WriteCommand(0x00);
    OLED_WriteCommand(0x40);  // Set start line (0)
    OLED_WriteCommand(0x8D);  // Charge pump setting
    OLED_WriteCommand(0x14);  // Enable charge pump
    OLED_WriteCommand(0x20);  // Memory addressing mode
    OLED_WriteCommand(0x00);  // Horizontal
    OLED_WriteCommand(0xA1);  // Segment remap
    OLED_WriteCommand(0xC8);  // COM output scan direction
    OLED_WriteCommand(0xDA);  // COM pins hardware config
    OLED_WriteCommand(0x12);
    OLED_WriteCommand(0x81);  // Set contrast
    OLED_WriteCommand(0xCF);
    OLED_WriteCommand(0xD9);  // Set pre-charge period
    OLED_WriteCommand(0xF1);
    OLED_WriteCommand(0xDB);  // Set VCOMH deselect level
    OLED_WriteCommand(0x40);
    OLED_WriteCommand(0xA4);  // Resume to RAM content
    OLED_WriteCommand(0xA6);  // Normal display
    OLED_WriteCommand(0x2E);  // Deactivate scroll
    OLED_WriteCommand(0xAF);  // Display ON
    
    HAL_Delay(100);
}

void OLED_Clear(void) {
    for (uint8_t page = 0; page < 8; page++) {
        OLED_WriteCommand(0xB0 + page);
        OLED_WriteCommand(0x00);
        OLED_WriteCommand(0x10);
        for (uint8_t col = 0; col < 128; col++) {
            OLED_WriteData(0x00);
        }
    }
}

void OLED_SetCursor(uint8_t x, uint8_t y) {
    OLED_WriteCommand(0xB0 + y);
    OLED_WriteCommand((x & 0x0F));
    OLED_WriteCommand(0x10 | ((x >> 4) & 0x0F));
}

/* Simple font for numbers and letters */
