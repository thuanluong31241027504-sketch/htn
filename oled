  MX_GPIO_Init();
  MX_I2C1_Init();

  /* USER CODE BEGIN 2 */
  
  LED_Blink(2, 200);
  OLED_Init();
  
  /* USER CODE END 2 */

  while (1)
  {
    /* USER CODE BEGIN 3 */
    
    // Hiển thị lần lượt các biểu cảm, mỗi biểu cảm 2 giây
    OLED_DrawFace_Happy();
    HAL_Delay(2000);
    
    OLED_DrawFace_Sad();
    HAL_Delay(2000);
    
    OLED_DrawFace_Surprised();
    HAL_Delay(2000);
    
    OLED_DrawFace_Wink();
    HAL_Delay(2000);
    
    OLED_DrawFace_Heart();
    HAL_Delay(2000);
    
