// Vẽ mặt cười lớn
void OLED_DrawFace_BigSmile(void) {
    OLED_Clear();
    OLED_DrawCircle(64, 32, 28, 1);
    
    // Mắt (gạch ngang - đang nhắm)
    for (int i = 48; i <= 56; i++) OLED_DrawPixel(i, 21, 1);
    for (int i = 72; i <= 80; i++) OLED_DrawPixel(i, 21, 1);
    
    // Miệng cười to
    for (int i = -20; i <= 20; i++) {
        int y = 12 - (i * i) / 25;
        OLED_DrawPixel(64 + i, 42 + y, 1);
    }
    OLED_Update();
}

