int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_I2C2_Init();    // I2C2 for VL53L0X
  MX_USART1_UART_Init();

  /* USER CODE BEGIN 2 */
  
  UART_Print("\r\n=== SYSTEM START ===\r\n");
  LED_Blink(2, 200);
  
  /* Initialize OLED */
  OLED_Init();
  UART_Print("[OK] OLED initialized on I2C1 (PB6,PB7)\r\n");
  
  /* Initialize VL53L0X */
  laser_ok = VL53L0X_Init();
  if (laser_ok) {
      UART_Print("[OK] VL53L0X initialized on I2C2 (PB10,PB11)\r\n");
      LED_Blink(2, 100);
  } else {
      UART_Print("[ERROR] VL53L0X not found!\r\n");
      LED_Blink(5, 200);
  }
  
  UART_Print("================================\r\n");
  
  /* USER CODE END 2 */

  while (1)
  {
    /* USER CODE BEGIN 3 */
    
    /* Read distance if VL53L0X is OK */
    if (laser_ok) {
        laser_distance = VL53L0X_ReadDistance();
        if (laser_distance < 9999) {
            UART_PrintNumber("Distance: ", laser_distance, " mm\r\n");
        }
    }
    
    /* OLED Face Animation */
    OLED_DrawFace_Happy();
    HAL_Delay(2000);
    
    OLED_DrawFace_Sad();
    HAL_Delay(2000);
    
    OLED_DrawFace_Surprised();
    HAL_Delay(2000);
    
    OLED_DrawFace_Wink();
    HAL_Delay(2000);
    
    OLED_DrawFace_Heart();
    HAL_Delay(2000);
    
    OLED_DrawFace_BigSmile();
    HAL_Delay(2000);
    
    LED_Blink(1, 100);
    
    /* USER CODE END 3 */
  }
}

