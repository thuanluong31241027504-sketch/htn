    UART_Print("║     I2C CONTINUOUS SCANNER               ║\r\n");
    UART_Print("║     Testing VL53L0X connection           ║\r\n");
    UART_Print("╚════════════════════════════════════════════╝\r\n");
    UART_Print("\r\n");
    UART_Print("Scanning every 1 second...\r\n");
    UART_Print("----------------------------------------\r\n");
    
    LED_Blink(3, 200);
    /* USER CODE END 2 */

    /* Infinite loop */
    while (1)
    {
        /* USER CODE BEGIN 3 */
        I2C_Scan();
        HAL_Delay(1000);
        /* USER CODE END 3 */
    }
}

