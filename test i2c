/* USER CODE BEGIN 0 */
static void LED_On(void) {
    HAL_GPIO_WritePin(LED_PORT, LED_PIN, GPIO_PIN_SET);
}

static void LED_Off(void) {
    HAL_GPIO_WritePin(LED_PORT, LED_PIN, GPIO_PIN_RESET);
}

static void LED_Blink(uint32_t times, uint32_t delay_ms) {
    for (uint32_t i = 0; i < times; i++) {
        LED_On();
        HAL_Delay(delay_ms);
        LED_Off();
        HAL_Delay(delay_ms);
    }
}

static void UART_Print(const char *msg) {
    HAL_UART_Transmit(&huart1, (uint8_t*)msg, strlen(msg), 100);
}

static void UART_PrintNumber(const char *prefix, uint32_t num, const char *suffix) {
    char buffer[64];
    int len = sprintf(buffer, "%s%lu%s", prefix, num, suffix);
    HAL_UART_Transmit(&huart1, (uint8_t*)buffer, len, 100);
}

static void I2C_Scan(void) {
    uint8_t found_29 = 0;
    uint8_t found_41 = 0;
    
    /* Scan all I2C addresses */
    for (uint8_t addr = 1; addr < 127; addr++) {
        if (HAL_I2C_IsDeviceReady(&hi2c1, addr << 1, 3, 50) == HAL_OK) {
            if (addr == VL53L0X_ADDR_29) found_29 = 1;
            if (addr == VL53L0X_ADDR_41) found_41 = 1;
        }
    }
    
    /* Report status */
    if (found_29) {
        UART_Print("[OK] VL53L0X found at 0x29\r\n");
        LED_Blink(1, 30);
    } else if (found_41) {
        UART_Print("[OK] VL53L0X found at 0x41\r\n");
        LED_Blink(1, 30);
    } else {
        UART_Print("[WARN] No VL53L0X found\r\n");
        LED_Off();
    }
}
/* USER CODE END 0 */

int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
